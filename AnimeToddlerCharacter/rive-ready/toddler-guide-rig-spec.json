    "beforeAuthoringHandsUp": [
      "Rotate both upper-arm bones upward manually and confirm both shoulders produce a smooth, balanced arc.",
      "Rotate both lower-arm bones upward manually and confirm both elbows stay soft and connected without drifting.",
      "Rotate both hand bones lightly and confirm the hands follow the arm chains naturally.",
      "Stop and correct pivots or bindings before authoring handsUp if either side bends unnaturally, distorts, or drifts."
    ],
    "beforeAuthoringBreathe": [
      "Test gentle torso expansion manually and confirm the torso can scale subtly without visible distortion.",
      "Confirm the head remains aligned with the torso during small torso lift and release.",
      "Confirm the shoulders can rise and soften very slightly without breaking the arm placement.",
      "Stop and correct the structure before authoring breathe if the torso scales unevenly, distorts, or shifts pivots badly."
    ],
    "beforeAuthoringSway": [
      "Test a small left and right torso shift manually and confirm the torso rotates subtly without visible distortion.",
      "Confirm the head follows the torso naturally with only tiny support motion.",
      "Confirm both arms can hang naturally while the torso shifts side to side.",
      "Confirm the legs and feet remain visually grounded; stop and fix pivots or binding if the body distorts, the feet slide badly, or the head drifts unnaturally."
    ],
    "beforeAuthoringJump": [
      "Test a small squat manually and confirm both upper legs rotate cleanly from the hips.",
      "Confirm both lower legs bend naturally from the knees and the feet stay attached.",
      "Confirm the torso can move slightly up and down without visible distortion.",
      "Stop and fix pivots or binding before authoring jump if the knees bend badly, the feet detach, or the torso compresses unnaturally."
    ],
    "beforeAuthoringCelebrate": [
      "Confirm both arms can lift comfortably and stay readable in a friendly open arc.",
      "Confirm the head can support a tiny positive lift or tilt without drifting.",
      "Confirm the torso can support a small joyful bounce without distortion.",
      "Stop and stabilize the rig before authoring celebrate if the pose system feels stiff or unstable."
    ]
