    "entry": "idle",
    "transitions": [
      {
        "from": "any",
        "to": "celebrate",
        "when": ["celebrate fired"],
        "mixSeconds": 0.12,
        "priority": "high"
      },
      {
        "from": "celebrate",
        "to": "idle",
        "when": ["animation complete"],
        "mixSeconds": 0.18
      },
      {
        "from": "idle",
        "to": "wave",
