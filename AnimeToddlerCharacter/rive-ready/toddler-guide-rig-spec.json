        "mixSeconds": 0.22
      },
      {
        "from": "idle",
        "to": "breathe",
        "when": ["isPlaying == true", "activityIndex == 6"],
        "mixSeconds": 0.25
      },
      {
        "from": "wave",
        "to": "idle",
